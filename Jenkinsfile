pipeline {
    agent any

    stages {
        stage('Start') {
            steps {
                echo 'Pipeline started'
            }
        }

        stage('Build') {
            steps {
                echo 'Building project...'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
            }
        }

        stage('Finish') {
            steps {
                echo 'Pipeline finished successfully'
            }
        }
    }
}